{
  "installCommand": "npm install && cd sda-frontend && npm install",
  "buildCommand": "npm run build:backend",
  "framework": null,
  "outputDirectory": "dist",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.js"
    }
  ]
}