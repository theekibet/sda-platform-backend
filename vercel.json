{
  "installCommand": "npm install && cd sda-frontend && npm install",
  "buildCommand": "npm run build:backend",
  "framework": null,
  "outputDirectory": "dist",
  "functions": {
    "api/index.js": {
      "runtime": "nodejs20.x",
      "includeFiles": "dist/**",
      "excludeFiles": "**/*.spec.ts"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.js"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}